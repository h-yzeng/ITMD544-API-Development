{
  "info": {
    "name": "Hospital Appointment System API",
    "description": "Complete collection for the Hospital Appointment System REST and GraphQL APIs. Import this file into Postman via File → Import.\n\nBase URL variable: {{baseUrl}}\nSet to https://hospital-appointment-api-k4kc.onrender.com for production\nSet to http://localhost:3000 for local development",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://hospital-appointment-api-k4kc.onrender.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns {\"status\": \"ok\"} if the server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "List All Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Returns a paginated list of all patients."
          },
          "response": []
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1"]
            },
            "description": "Returns a single patient by ID. Returns 404 if not found."
          },
          "response": []
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phone\": \"555-1234\",\n  \"date_of_birth\": \"1990-05-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            },
            "description": "Creates a new patient. Returns 201 with the created record. Returns 400 if validation fails (missing required fields or invalid email format)."
          },
          "response": []
        },
        {
          "name": "Create Patient — Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"email\": \"not-a-valid-email\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            },
            "description": "Demonstrates Zod validation error — missing last_name and invalid email format. Returns 400 with field-level errors."
          },
          "response": []
        },
        {
          "name": "Get Patient Appointments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/1/appointments?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1", "appointments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Returns all appointments for a specific patient. Returns 404 if patient does not exist."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "List All Doctors",
          "request": {
            "method": "GET",
